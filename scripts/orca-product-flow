#!/bin/zsh

set -euo pipefail

readonly SCRIPT_DIR="${0:A:h}"
readonly ROOT="${SCRIPT_DIR:h}"
readonly PROJECTS_ROOT="${PROJECTS_ROOT:-${ROOT:h}}"
readonly ANALYTICS="${UG_ANALYTICS_DIR:-$PROJECTS_ROOT/ug-analytics}"
readonly CONFLUENCE="${CONFLUENCE_TOOLS_DIR:-$PROJECTS_ROOT/work/automations/confluence_tools}"
readonly HANDOFF="$SCRIPT_DIR/orca-handoff"

application_cli() {
  local application_name="$1"
  local relative_cli="$2"
  local application_path

  application_path=$(osascript -e "POSIX path of (path to application \"$application_name\")" 2>/dev/null) || return 1
  print -r -- "${application_path%/}/$relative_cli"
}

resolve_cli() {
  local override="$1"
  local command_name="$2"
  local application_name="$3"
  local relative_cli="$4"
  local discovered

  if [[ -n "$override" ]]; then
    print -r -- "$override"
    return 0
  fi

  discovered=$(command -v "$command_name" 2>/dev/null) && {
    print -r -- "$discovered"
    return 0
  }

  application_cli "$application_name" "$relative_cli"
}

readonly ORCA="$(resolve_cli "${ORCA_BIN:-}" orca "Orca 2" "Contents/Resources/bin/orca" || true)"
readonly CLAUDE="$(resolve_cli "${CLAUDE_BIN:-}" claude "Claude" "Contents/MacOS/claude" || true)"

fail() {
  print -u2 -- "UG Product Flow: $*"
  exit 1
}

terminal_handle() {
  jq -r '[
    .result.startupTerminal.handle?,
    .result.terminal.handle?,
    .result.terminalHandle?,
    .result.handle?,
    .result.terminal?,
    .terminal.handle?,
    .terminalHandle?,
    .handle?
  ] | map(select(type == "string" and length > 0)) | .[0] // empty'
}

[[ -n "$ORCA" && -x "$ORCA" ]] || fail "Orca CLI not found. Put 'orca' on PATH or set ORCA_BIN."
[[ -n "$CLAUDE" && -x "$CLAUDE" ]] || fail "Claude Code not found. Put 'claude' on PATH or set CLAUDE_BIN."
[[ -x "$HANDOFF" ]] || fail "handoff runner is not executable: $HANDOFF"
[[ -d "$ANALYTICS" ]] || fail "ug-analytics not found: $ANALYTICS. Set UG_ANALYTICS_DIR."
[[ -d "$CONFLUENCE" ]] || fail "Confluence tools not found: $CONFLUENCE. Set CONFLUENCE_TOOLS_DIR."
command -v jq >/dev/null || fail "jq is required"

cd "$ROOT" || fail "cannot open $ROOT"

if ! "$ORCA" open --json >/dev/null; then
  fail "Orca did not start. Open $ORCA_APP once and run this launcher again."
fi

repo_json=$("$ORCA" repo list --json)
if ! print -r -- "$repo_json" | jq -e --arg root "$ROOT" '.. | objects | select(.path? == $root)' >/dev/null; then
  "$ORCA" repo add --path "$ROOT" --json >/dev/null || fail "could not add the repository to Orca"
fi

claude_command="export PYTHONPATH=${(q)ANALYTICS}\${PYTHONPATH:+:\$PYTHONPATH}; exec ${(q)CLAUDE} --add-dir ${(q)ANALYTICS} --add-dir ${(q)CONFLUENCE}"
claude_json=$("$ORCA" terminal create \
  --worktree "path:$ROOT" \
  --title "Claude · UG Product Manager" \
  --command "$claude_command" \
  --focus \
  --json)
claude_handle=$(print -r -- "$claude_json" | terminal_handle)
[[ -n "$claude_handle" ]] || fail "Orca created Claude, but returned no terminal handle"

handoff_command="exec ${(q)HANDOFF} ${(q)claude_handle}"
handoff_json=$("$ORCA" terminal create \
  --worktree "path:$ROOT" \
  --title "Orca · Claude → Codex handoff" \
  --command "$handoff_command" \
  --json)
handoff_handle=$(print -r -- "$handoff_json" | terminal_handle)
[[ -n "$handoff_handle" ]] || fail "Orca created the handoff runner, but returned no terminal handle"

print -- "UG Product Flow is running in Orca."
print -- "Claude terminal: $claude_handle"
print -- "Handoff terminal: $handoff_handle"
